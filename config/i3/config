# ======================================
# i3-specific configuration
# these settings apply only to i3wm and may not be compatible with sway
# ======================================

# I'm using Mod4 as Mod1 and viceversa: 'setkxkbmap -option "altwin:swap_alt_win"'
#set $mod Mod1
set $mod Mod4

# dmenu
set $normbgcolor #000000
set $normfgcolor #ff00ff
set $selbgcolor #000000
set $selfgcolor #00ff00
# window borders
set $normbordercolor #000000
set $selbordercolor #ff00ff
set $inacbordercolor #444444
set $urgentcolor #ee0080

set $font_family monospace
#set $font_family Hack
set $font_size 8
font pango:$font_family $font_size

# old #be00ee
# class                 border              background         text                indicator          child_border
client.focused          $selbordercolor     $selbordercolor    $normbordercolor    $selbordercolor    $selbordercolor
client.focused_inactive $inacbordercolor    $inacbordercolor   $normbordercolor    $inacbordercolor   $inacbordercolor
client.unfocused        $normbordercolor    $normbordercolor   $selbordercolor     $normbordercolor   $normbordercolor
client.urgent           $urgentcolor        $urgentcolor       $normbordercolor    $urgentcolor       $urgentcolor
client.placeholder      $selbordercolor     $selbordercolor    $normbordercolor    $selbordercolor    $selbordercolor
client.background       $normbgcolor

bar {
	id bar-1
	status_command i3status -c ~/.config/i3status/i3status.conf
	#i3bar_command i3bar --transparency
	# note: 'i3bar_command' is not sway compatible
	font pango:$font_family $font_size

	colors {
		background $normbgcolorb3
		statusline #eeeeee
		separator $normfgcolor

		#:'<,'>s/b3/xx/g
		# class            #border             #background         #text
		focused_workspace  $normbgcolorb3      $normbgcolorb3      $selfgcolorb3
		active_workspace   #222222b3           #aaaaaab3           #555555b3
		inactive_workspace $normbgcolorb3      $normbgcolorb3      #888888b3
		urgent_workspace   $urgentcolorb3      $urgentcolorb3      #000000b3
		binding_mode       $normbgcolorb3      $normbgcolorb3      $urgentcolorb3
	}

	#mode hide
	#mode invisible
	#position top
	tray_output none
	tray_padding 0 px
	separator_symbol ":|:"
	#strip_workspace_numbers yes

	#height 18
	# do not use height restrictions if using different scales,
	# refer to ~/.Xresources
}
