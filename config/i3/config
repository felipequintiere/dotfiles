# --------------------------------------
bindsym $mod+Control+x exec ~/.config/settings/x11_brightness_up.sh
bindsym $mod+Control+z exec ~/.config/settings/x11_brightness_down.sh

bindsym $mod+Return exec --no-startup-id xterm
bindsym $mod+Shift+Return exec --no-startup-id sh -c 'xterm -e tmux'

bindsym $mod+Control+g exec --no-startup-id \
	sh -c \
	'maim -s | tee ~/.screenshot/$(date +%Hh_%Mmin_%Ssec).png | xclip -selection clipboard -t image/png'
bindsym $mod+Shift+g exec --no-startup-id \
	sh -c \
	'maim -s -b 2 -q | xclip -selection clipboard -t image/png'

# use 'floating_modifier $mod normal' on sway
floating_modifier $mod

# actually, 'exec i3-msg' works on sway - restart doesn't
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q exec "i3-nagbar -t warning -m 'do you really wanna exit i3?' -B 'yes' 'i3-msg exit'"



set $modx meta-ex
mode $modx {
	bindsym $mod+b split h, mode default
	bindsym $mod+h split h, mode default
	bindsym $mod+v split v, mode default

	#bindsym $mod+Shift+b bar mode toggle
	#bindsym $mod+Shift+b bar hidden_state toggle
	bindsym $mod+Shift+b exec --no-startup-id ~/.config/i3/.toggle_i3bar.sh, mode default

	bindsym Return mode "default"
	bindsym Escape mode "default"
	bindsym Control+c mode "default"
	bindsym Control+bracketleft mode "default"
	bindsym Control+g mode "default"
}
bindsym $mod+x mode $modx

mode "menu" {
	bindsym $mod+d exec --no-startup-id \
		dmenu_run -i \
		-fn "$font_family:size=$font_size" \
		-nb "$normbgcolor" \
		-nf "$normfgcolor" \
		-sb "$selbgcolor" \
		-sf "$selfgcolor", mode default

	bindsym $mod+p exec --no-startup-id \
		dmenu_run -i \
		-fn "$font_family:size=$font_size" \
		-nb "$normbgcolor" \
		-nf "$normfgcolor" \
		-sb "$selbgcolor" \
		-sf "$selfgcolor", mode default

	bindsym $mod+r exec --no-startup-id \
		~/.config/i3/dmenu/dmenu_zathura.sh, mode default
	bindsym r exec --no-startup-id \
		~/.config/i3/dmenu/dmenu_zathura.sh, mode default

	bindsym $mod+w exec --no-startup-id \
		~/.config/i3/dmenu/dmenu_xournalpp.sh, mode default
	bindsym w exec --no-startup-id \
		~/.config/i3/dmenu/dmenu_xournalpp.sh, mode default

	bindsym $mod+t exec --no-startup-id \
		~/.config/i3/dmenu/dmenu_tablet.sh, mode default
	bindsym t exec --no-startup-id \
		~/.config/i3/dmenu/dmenu_tablet.sh, mode default

	bindsym Return mode "default"
	bindsym Escape mode "default"
	bindsym Control+c mode "default"
	bindsym Control+bracketleft mode "default"
	bindsym Control+g mode "default"
}
bindsym $mod+d mode "menu"
